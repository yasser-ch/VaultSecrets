<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔑"
            android:textSize="40sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VaultSecrets"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvIcon"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secrets, KMS et migrations Room"
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Section DB -->
        <TextView
            android:id="@+id/tvDbLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BASE DE DONNÉES"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/llDb"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvDbLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestDb"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🗃️  Tester Room + Migrations"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"
                app:backgroundTint="@color/purple_primary"
                app:cornerRadius="14dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestSql"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🛡️  Demo Anti-Injection SQL"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

        </LinearLayout>

        <!-- Section KMS -->
        <TextView
            android:id="@+id/tvKmsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GESTION DES SECRETS"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/llDb"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/llKms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvKmsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGetKey"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔑  Récupérer clé KMS"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"
                app:backgroundTint="@color/purple_primary"
                app:cornerRadius="14dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyHmac"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✅  Vérifier HMAC"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAuditSecrets"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔍  Audit secrets hardcodés"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearCache"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🗑️  Vider le cache"
                android:textSize="15sp"
                app:backgroundTint="@color/danger"
                app:cornerRadius="14dp"/>

        </LinearLayout>

        <!-- Résultat -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card_dark"
            app:layout_constraintTop_toBottomOf="@id/llKms"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Résultat"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:minHeight="120dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>